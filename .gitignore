# ============================================================
# EximJunction — Root .gitignore
# Covers: trade-data-api/ + trade-frontend/ + test-suite-v2/
# ============================================================

# ── Archived / staging folders ───────────────────────────────
old/
demo/
latest_changes/
trade-api-staging/
trade_site_QA/
portal-staging/
demo-package/

# ── Zip and distribution files ───────────────────────────────
*.zip
*.tar.gz
*.tar

# ── Word / Excel / PowerPoint docs at root ───────────────────
*.docx
*.xlsx
*.pptx
*.doc

# ── Root-level scripts (not for version control) ─────────────
run_ingestion.ps1

# ── OS generated files ───────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Logs at root level ───────────────────────────────────────
*.log
ingestion_log.txt
npm-debug.log*


# ============================================================
# trade-data-api/ — Python / FastAPI Backend
# ============================================================

# Python bytecode
trade-data-api/**/__pycache__/
trade-data-api/**/*.py[cod]
trade-data-api/**/*.pyo
trade-data-api/**/*.pyd
trade-data-api/**/*.so

# Virtual environment — NEVER commit
trade-data-api/venv/
trade-data-api/env/
trade-data-api/.venv/
trade-data-api/ENV/

# Environment variables — NEVER commit (contains secrets)
trade-data-api/.env
trade-data-api/.env.*
trade-data-api/*.env

# Database files — contain real user data
trade-data-api/*.db
trade-data-api/*.sqlite
trade-data-api/*.sqlite3

# Build artifacts
trade-data-api/dist/
trade-data-api/build/
trade-data-api/*.egg-info/
trade-data-api/.eggs/

# Logs
trade-data-api/logs/
trade-data-api/*.log

# Backup files created during editing
trade-data-api/app/main_backup.py
trade-data-api/**/*.backup

# Test artifacts
trade-data-api/.pytest_cache/
trade-data-api/.coverage
trade-data-api/htmlcov/
trade-data-api/coverage-report/

# IDE
trade-data-api/.vscode/
trade-data-api/.idea/
trade-data-api/**/*.swp
trade-data-api/**/*.swo


# ============================================================
# trade-frontend/ — React / Vite / Tailwind Frontend
# ============================================================

# Node modules — NEVER commit (huge, regenerated by npm install)
trade-frontend/node_modules/

# Build output — generated by npm run build
trade-frontend/dist/
trade-frontend/build/
trade-frontend/.vite/

# Environment variables — NEVER commit (contains API keys)
trade-frontend/.env
trade-frontend/.env.*
trade-frontend/.env.local
trade-frontend/.env.development.local
trade-frontend/.env.test.local
# NOTE: .env.production IS committed as it contains no secrets
# (only public VITE_ variables pointing to your domain)

# npm logs
trade-frontend/npm-debug.log*
trade-frontend/yarn-debug.log*
trade-frontend/yarn-error.log*
trade-frontend/pnpm-debug.log*

# IDE
trade-frontend/.vscode/
trade-frontend/.idea/

# Test artifacts
trade-frontend/playwright-report/
trade-frontend/test-results/
trade-frontend/allure-results/
trade-frontend/allure-report/


# ============================================================
# test-suite-v2/ — QA Suite (pytest-bdd + Playwright + Locust)
# ============================================================

# Python bytecode
test-suite-v2/**/__pycache__/
test-suite-v2/**/*.py[cod]
test-suite-v2/**/*.pyo

# pytest cache
test-suite-v2/.pytest_cache/

# Environment config for tests — contains server URLs and credentials
test-suite-v2/.env
test-suite-v2/.env.*
test-suite-v2/.env.test

# Test output — generated files, not source code
test-suite-v2/allure-results/
test-suite-v2/allure-report/
test-suite-v2/coverage-report/
test-suite-v2/.coverage

# Performance test reports — generated output
test-suite-v2/tests/performance/reports/

# HTML reports — generated output
test-suite-v2/test-report.html
test-suite-v2/*.html

# Text result logs — generated output
test-suite-v2/*.txt
test-suite-v2/full_test_results.txt
test-suite-v2/backend_results.txt
test-suite-v2/frontend_results.txt
test-suite-v2/smoke_results.txt
test-suite-v2/locust_results.txt

# Screenshots captured during Playwright tests
test-suite-v2/allure-results/screenshots/

# IDE
test-suite-v2/.vscode/
test-suite-v2/.idea/
